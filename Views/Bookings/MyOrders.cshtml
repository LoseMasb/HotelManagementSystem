@model IEnumerable<HotelManagementSystem.ViewModels.Customer.MyBookingItemVm>
@{
    ViewData["Title"] = "我的订单";
}

<section class="glass-card p-4 p-md-5 mb-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <p class="eyebrow mb-2">MY BOOKINGS</p>
            <h2 class="mb-1">我的订单</h2>
            <p class="section-subtitle mb-0">可查看历史预订、状态与下单时间。</p>
        </div>
        <div class="hero-metrics">
            <div class="metric-card">
                <span class="metric-value">@Model.Count()</span>
                <span class="metric-label">订单总数</span>
            </div>
        </div>
    </div>
</section>

<section class="glass-card p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
            <tr>
                <th>订单号</th>
                <th>酒店</th>
                <th>房型</th>
                <th>入住/离店</th>
                <th>数量</th>
                <th>单价</th>
                <th>状态</th>
                <th>下单时间</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var x in Model)
            {
                <tr>
                    <td class="fw-semibold">#@x.BookingId</td>
                    <td>@x.HotelName</td>
                    <td>@x.RoomTypeName</td>
                    <td>@x.CheckInDate ~ @x.CheckOutDate</td>
                    <td>@x.Quantity</td>
                    <td>￥@x.UnitPrice</td>
                    <td><span class="badge text-bg-light border">@x.Status</span></td>
                    <td>@x.CreatedAt.ToLocalTime()</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light border mt-3 mb-0">你还没有订单，去酒店列表看看吧。</div>
    }
</section>