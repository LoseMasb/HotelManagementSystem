@using HotelManagementSystem.Data
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 酒店管理系统</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HotelManagementSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main-content">跳到主内容</a>

    <div class="bg-aurora" aria-hidden="true">
        <span class="orb orb-a"></span>
        <span class="orb orb-b"></span>
        <span class="orb orb-c"></span>
        <span class="noise"></span>
    </div>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark oc-navbar sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold oc-brand" asp-area="" asp-controller="Hotels" asp-action="Index">🏨 酒店管理系统</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="切换导航">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Hotels" asp-action="Index">酒店列表</a></li>
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole(SeedData.CustomerRole))
                        {
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Bookings" asp-action="MyOrders">我的订单</a></li>
                        }
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole(SeedData.HotelManagerRole))
                        {
                            <li class="nav-item"><a class="nav-link" asp-area="HotelManager" asp-controller="Hotels" asp-action="Edit">酒店端</a></li>
                        }
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole(SeedData.AdminRole))
                        {
                            <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Hotels" asp-action="Index">管理后台</a></li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content" class="container py-4 page-shell" tabindex="-1">
        <partial name="_AlertPartial" />
        @RenderBody()
    </main>

    <footer class="oc-footer py-3 mt-4">
        <div class="container d-flex justify-content-between flex-wrap gap-2 small">
            <span>© @DateTime.Now.Year 酒店管理系统</span>
            <span>Immersive · Motion-first · Accessible</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>