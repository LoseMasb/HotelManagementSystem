@model HotelManagementSystem.ViewModels.Admin.HotelEditVm
@{
    ViewData["Title"] = Model.Id.HasValue ? "编辑酒店" : "新增酒店";
    var managers = ViewBag.Managers as List<HotelManagementSystem.ViewModels.Admin.ManagerOptionVm> ?? new();
    var selected = ViewBag.SelectedManager as string;
}
<div class="card border-0 shadow-sm"><div class="card-body">
    <h4>@ViewData["Title"]</h4>
    <form method="post">
        @Html.AntiForgeryToken()
        @if (Model.Id.HasValue){<input type="hidden" asp-for="Id" />}
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="City" class="form-label"></label><input asp-for="City" class="form-control" /><span asp-validation-for="City" class="text-danger"></span></div>
            <div class="col-12"><label asp-for="Address" class="form-label"></label><input asp-for="Address" class="form-control" /></div>
            <div class="col-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control"></textarea></div>
            <div class="col-md-6">
                <label class="form-label">酒店管理员</label>
                <select name="ManagerUserId" class="form-select">
                    <option value="">-- 未分配 --</option>
                    @foreach (var m in managers)
                    {
                        <option value="@m.UserId" selected="@(Model.ManagerUserId == m.UserId || selected == m.UserId)">@m.Email</option>
                    }
                </select>
            </div>
            <div class="col-md-6 d-flex align-items-end"><div class="form-check"><input asp-for="IsEnabled" class="form-check-input" /><label asp-for="IsEnabled" class="form-check-label">启用酒店</label></div></div>
        </div>
        <div class="mt-3"><button class="btn btn-primary">保存</button> <a class="btn btn-outline-secondary" asp-action="Index">返回</a></div>
    </form>
</div></div>
@section Scripts{<partial name="_ValidationScriptsPartial" />}
